# =============================================================================
# Variables de entorno del SGI MSU
# =============================================================================
# Copiar este archivo a .env.local (NUNCA commitear .env.local)
# En Vercel: configurar estas variables en Project Settings > Environment Variables
# =============================================================================

# URL pública del proyecto Supabase
# Se obtiene en: dashboard.supabase.com > tu proyecto > Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://hghzpuvxggvpgwzpzaqw.supabase.co

# Clave pública anónima del proyecto Supabase
# Se obtiene en: dashboard.supabase.com > tu proyecto > Project Settings > API > Project API keys > anon public
# Es segura para exponer al cliente porque RLS limita lo que puede hacer cada usuario.
NEXT_PUBLIC_SUPABASE_ANON_KEY=pegar-aqui-tu-anon-key
